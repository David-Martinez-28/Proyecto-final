:80 {
    # 1. Rutas de API: envía todo a index.php de Laravel
    route /api/* {
        root * /var/www/public
        # El punto clave es este bloque de php_fastcgi
        php_fastcgi php:9000 {
            index index.php
        }
    }

    # 2. Archivos estáticos
    route /storage/* {
        root * /var/www/public
        file_server
    }

    # 3. Frontend
    reverse_proxy react:5173
}